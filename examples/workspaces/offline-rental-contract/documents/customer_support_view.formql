// formql: table=rental_contract
contract_number,
LOWER(COALESCE(customer_id__rel.email, rep_id__rel.email, vehicle_id__rel.vendor_id__rel.support_email)) AS support_email,
customer_id__rel.loyalty_tier,
customer_id__rel.prior_contract_count,
IF(customer_id__rel.repeat_customer = TRUE, "repeat", "new") AS customer_segment,
branch_id__rel.region AS branch_region,
vehicle_id__rel.vendor_id__rel.name AS vendor_name,
IF(ISBLANK(TRIM(vehicle_id__rel.vendor_id__rel.support_email)), "needs-vendor-followup", "ready") AS vendor_support_status
