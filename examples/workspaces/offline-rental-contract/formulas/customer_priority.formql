// formql: table=rental_contract
// Repeat-customer routing with a multi-argument AND.
IF(AND(customer_id__rel.repeat_customer = TRUE, customer_id__rel.prior_contract_count > 5, actual_days >= 3), customer_id__rel.first_name & " " & customer_id__rel.last_name & " / " & customer_id__rel.assigned_rep_id__rel.first_name, customer_id__rel.first_name & " " & customer_id__rel.last_name)
