// formql: table=resale_sale
vehicle_id__rel.model_name AS vehicle_model,
vehicle_id__rel.model_year,
customer_id__rel.email AS buyer_email,
rep_id__rel.manager_id__rel.last_name AS manager_last_name,
branch_id__rel.name AS branch_name,
sale_price,
margin_amount,
ABS(margin_amount) AS margin_abs,
IF(margin_amount > 4000, "strong-margin", IF(trade_in = TRUE, "trade-in", "thin-margin")) AS margin_band
