vehicle_rel.model_name AS vehicle_model,
vehicle_rel.model_year,
customer_rel.email AS buyer_email,
rep_rel.manager_rel.last_name AS manager_last_name,
branch_rel.name AS branch_name,
sale_price,
margin_amount,
ABS(margin_amount) AS margin_abs,
IF(margin_amount > 4000, "strong-margin", IF(trade_in = TRUE, "trade-in", "thin-margin")) AS margin_band
