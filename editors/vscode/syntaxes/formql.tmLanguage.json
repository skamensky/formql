{
  "scopeName": "source.formql",
  "name": "FormQL",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#functions"
    },
    {
      "include": "#relationships"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.formql",
          "match": "//.*$"
        },
        {
          "name": "comment.block.formql",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.formql",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.formql",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.formql",
          "match": "\\b\\d+(?:\\.\\d+)?\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.formql",
          "match": "\\b(?:TRUE|FALSE|NULL)\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function.formql",
          "match": "\\b(?:IF|AND|OR|NOT|STRING|DATE|COALESCE|NULLVALUE|ISNULL|ISBLANK|TODAY|ABS|ROUND|LEN|UPPER|LOWER|TRIM)\\b(?=\\s*\\()"
        }
      ]
    },
    "relationships": {
      "patterns": [
        {
          "name": "variable.other.relationship.formql",
          "match": "\\b[a-zA-Z_][a-zA-Z0-9_]*_rel\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.formql",
          "match": "\\+|-|\\*|/|&|=|!=|<>|<=|>=|<|>|\\."
        }
      ]
    }
  }
}
